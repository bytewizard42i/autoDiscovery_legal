{
  "name": "@meshsdk/counter-contract",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "compact": "npm run compact:counter",
    "compact:counter": "compact compile +0.27.0 src/counter.compact src/managed/counter",
    "compact:discovery-core": "compact compile +0.27.0 src/contracts/discovery-core.compact src/managed/discovery-core",
    "compact:jurisdiction-registry": "compact compile +0.27.0 src/contracts/jurisdiction-registry.compact src/managed/jurisdiction-registry",
    "compact:compliance-proof": "compact compile +0.27.0 src/contracts/compliance-proof.compact src/managed/compliance-proof",
    "compact:expert-witness": "compact compile +0.27.0 src/contracts/expert-witness.compact src/managed/expert-witness",
    "compact:ad": "npm run compact:discovery-core && npm run compact:jurisdiction-registry && npm run compact:compliance-proof",
    "compact:all": "npm run compact:counter && npm run compact:ad",
    "test": "vitest run",
    "test:compile": "npm run compact:all && vitest run",
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/contracts ./dist/contracts",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "toolkit-version": "bash src/toolkit/version.sh"  
  }
}
